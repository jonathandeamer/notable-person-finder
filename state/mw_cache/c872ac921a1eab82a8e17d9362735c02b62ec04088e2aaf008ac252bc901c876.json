{"batchcomplete": "", "query": {"pages": {"39539793": {"pageid": 39539793, "ns": 0, "title": "The Judge (2014 film)", "contentmodel": "wikitext", "pagelanguage": "en", "pagelanguagehtmlcode": "en", "pagelanguagedir": "ltr", "touched": "2026-02-18T22:37:30Z", "lastrevid": 1339095750, "length": 22627, "fullurl": "https://en.wikipedia.org/wiki/The_Judge_(2014_film)", "editurl": "https://en.wikipedia.org/w/index.php?title=The_Judge_(2014_film)&action=edit", "canonicalurl": "https://en.wikipedia.org/wiki/The_Judge_(2014_film)", "pageprops": {"defaultsort": "Judge (2014 film), The", "displaytitle": "<i>The Judge</i> (2014 film)", "page_image": "The_Judge_2014_film_poster.jpg", "wikibase-shortdesc": "2014 film by David Dobkin", "wikibase_item": "Q13573278"}, "description": "2014 film by David Dobkin", "descriptionsource": "local", "extract": "The Judge is a 2014 American legal drama film directed by David Dobkin. The film stars Robert Downey Jr. and Robert Duvall with Vera Farmiga, Vincent D'Onofrio, Jeremy Strong, Dax Shepard and Billy Bob Thornton in supporting roles.\nThe film was released in the United States on October 10, 2014 by Warner Bros. Pictures. It received mixed reviews from critics, but was praised for the performances of Duvall and Downey and Thomas Newman's score. The film grossed $84.4 million against a $45–50 million budget. Duvall received multiple award nominations for his performance as Judge Joseph Palmer, including the Academy Award, Golden Globe Award, Screen Actors Guild Award and Satellite Award for Best Supporting Actor. Thomas Newman received a Satellite Award nomination for Best Original Score.\n\n", "categories": [{"ns": 14, "title": "Category:2010s legal drama films"}, {"ns": 14, "title": "Category:2014 American films"}, {"ns": 14, "title": "Category:2014 English-language films"}, {"ns": 14, "title": "Category:2014 crime drama films"}, {"ns": 14, "title": "Category:2014 drama films"}, {"ns": 14, "title": "Category:2014 films"}, {"ns": 14, "t